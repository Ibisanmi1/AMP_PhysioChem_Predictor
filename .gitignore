# --- AMP_PhysioChem_Predictor ---
# Keep tracked: source, app.py, CITATION.*, README, requirements, small data/*.csv as needed.
# Hugging Face Spaces reject large binaries in plain Git — use Hub, Space "Files", or Git LFS/Xet.
# See docs/hf-space/DEPLOY.md

# Weight files: ignored by default (large binaries); tracked when under checkpoints/.
*.pt
*.pth
*.ckpt
!checkpoints/**/*.pt
!checkpoints/**/*.pth
!checkpoints/**/*.ckpt
output/
images/
data/dataanalysis/

# Full training runs (verbose logs — keep out of git unless you need them)
training_logs/

# Best-parameter JSON dumps (local tuning / search — not required for inference UI)
best_parameters/

# Internal docs (omit security notes from git); keep HF deploy guide tracked
docs/*
!docs/hf-space/
!docs/hf-space/**

# Local tool caches (e.g. matplotlib font cache under repo)
.mplconfig/

# Cursor / local tooling
.cursor/

# ML experiment trackers
wandb/
mlruns/

# Test / type caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# Optional local bundles
*_figures_hires.zip
